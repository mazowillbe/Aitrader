# Server Configuration
PORT=3001

# Trading Mode: DEMO or LIVE
TRADING_MODE=DEMO

# Risk Management - Core
MAX_TRADE_SIZE=1000
MAX_DAILY_RISK=500

# Professional Risk Management
KELLY_FRACTION_MAX=0.25
MAX_PORTFOLIO_HEAT=0.06
MAX_CORRELATION=0.7
DRAWDOWN_PROTECTION_THRESHOLD=0.10

# AI Decision Interval (milliseconds)
AI_DECISION_INTERVAL=60000

# Supported Trading Symbols
SUPPORTED_SYMBOLS=BTC/USD,ETH/USD,EUR/USD,GBP/USD,AAPL,TSLA

# Feature Flags
ENABLE_POSITION_MANAGEMENT=true
ENABLE_TRAILING_STOPS=true
ENABLE_BREAKEVEN_STOPS=true

# Broker API Keys (for LIVE mode only)
# MT5_API_KEY=your_mt5_api_key
# MT5_API_URL=your_mt5_api_url
# BROKER_API_KEY=your_broker_api_key
# BROKER_API_URL=your_broker_api_url
