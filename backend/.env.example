# Backend Configuration

# Server
PORT=3001

# Trading Mode (DEMO or LIVE)
TRADING_MODE=DEMO

# Risk Management
MAX_TRADE_SIZE=1000
MAX_DAILY_RISK=500

# Kelly Criterion
KELLY_FRACTION_MAX=0.25
ENABLE_KELLY_SIZING=true

# Portfolio Risk
MAX_PORTFOLIO_HEAT=0.06
MAX_CORRELATION=0.7
DRAWDOWN_PROTECTION_THRESHOLD=0.10

# Feature Flags
ENABLE_MULTI_TIMEFRAME=true
ENABLE_REGIME_DETECTION=true
ENABLE_POSITION_MANAGEMENT=true
ENABLE_ECONOMIC_CALENDAR=true
ENABLE_SESSION_LOGIC=true
ENABLE_SELF_IMPROVEMENT=true
ENABLE_CORRELATION_TRACKING=true

# Position Management
POSITION_MONITOR_INTERVAL=5000

# Broker API (for live trading - NOT IMPLEMENTED YET)
# MT5_API_URL=
# MT5_API_KEY=
