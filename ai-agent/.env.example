# AI Agent Configuration

# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Decision Interval (milliseconds)
AI_DECISION_INTERVAL=60000

# Supported Symbols (comma-separated)
SUPPORTED_SYMBOLS=BTC/USD,ETH/USD,EUR/USD,AAPL,TSLA

# Market Data APIs (optional - will use demo data if not set)
COINGECKO_API_KEY=
ALPHA_VANTAGE_API_KEY=

# News API (optional)
NEWS_API_KEY=

# Economic Calendar API (optional)
ECONOMIC_CALENDAR_API_KEY=

# Feature Flags
ENABLE_MULTI_TIMEFRAME=true
ENABLE_REGIME_DETECTION=true
ENABLE_SESSION_LOGIC=true
ENABLE_ECONOMIC_CALENDAR=true
ENABLE_SELF_IMPROVEMENT=true

# Backend URL
BACKEND_URL=http://localhost:3001
